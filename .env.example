# Copy to backend/.env and fill in values. Never commit the real .env file.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/earningslens
ANTHROPIC_API_KEY=sk-ant-...
APP_URL=http://localhost:3000

# Required by SEC fair-use policy — requests without this header are blocked
EDGAR_USER_AGENT="EarningsLens yourname@email.com"

# Politeness delay (ms) between Motley Fool scrape requests
SCRAPER_DELAY_MS=1500

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,https://yourapp.up.railway.app

# External signal sources — all optional; missing sources are skipped gracefully
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
NEWSAPI_KEY=your_newsapi_key
FINNHUB_KEY=your_finnhub_key
